# Обязательные настройки
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_id_here
ADMIN_KEY=your_admin_key_here
SECRET_KEY=your_secret_key_here

# API ключи для генерации изображений (нужен хотя бы один)
OPENAI_API_KEY=your_openai_key_here
STABILITY_API_KEY=your_stability_key_here

# URL для webhook (укажите после деплоя)
WEBSITE_URL=https://your-app.onrender.com
WEBHOOK_URL=https://your-app.onrender.com

# Порт (Render использует свои порты)
PORT=5000
